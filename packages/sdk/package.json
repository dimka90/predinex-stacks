{
    "name": "predinex-stacks-sdk",
    "version": "0.1.1",
    "description": "Core SDK for Predinex Stacks interaction",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.mjs",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
        "lint": "eslint src/**",
        "test": "vitest"
    },
    "dependencies": {
        "@stacks/network": "^7.2.0",
        "@stacks/transactions": "^7.3.0"
    },
    "devDependencies": {
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "vitest": "^3.2.4"
    },
    "publishConfig": {
        "access": "public"
    }
}