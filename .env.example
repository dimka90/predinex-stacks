# Stacks Deployment Configuration
# Copy this file to .env and fill in your values

# Your wallet private key (64 character hex string)
# Get this from your Leather/Hiro wallet: Settings > Secret Key
# NEVER commit your actual private key to git!
DEPLOYER_KEY=your_64_character_hex_private_key_here
PRIVATE_KEY=your_64_character_hex_private_key_here

# Network to deploy to: 'testnet' or 'mainnet'
STACKS_NETWORK=mainnet

# Optional: sub-wallet orchestration
CONTRACT_ADDRESS=SP2WWKKF25SED3K5P6ETY7MDDNBQH50GPSP8EJM8N
CONTRACT_NAME=predinex-v2-master
ARMY_SIZE=60
SUB_WALLET_FUNDING_USTX=170000
SUB_WALLET_BET_USTX=1000
SUB_WALLET_STAKE_USTX=100
SUB_WALLET_TX_COUNT=5
FUNDING_FEE_USTX=10000
SUB_TX_FEE_USTX=20000

ANALYTICS_ENABLED=false
DEBUG_LEVEL=info
